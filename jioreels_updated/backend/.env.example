PORT=5002
MONGO_URI=mongodb://127.0.0.1:27017/jioreels
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=300d

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

CLIENT_URL=http://localhost:5002
NODE_ENV=production

# ── AI Content Moderation (FREE - 500 checks/day) ────────────────────────────
# Sign up FREE at: https://sightengine.com/
# Go to Dashboard → API Credentials → copy API User & Secret
SIGHTENGINE_USER=your_sightengine_api_user
SIGHTENGINE_SECRET=your_sightengine_api_secret

# ── Pexels API for continuous reel feed (FREE - 20,000 req/month) ─────────────
# Sign up FREE at: https://www.pexels.com/api/
# Go to your Pexels account → API → copy your API Key
PEXELS_API_KEY=your_pexels_api_key
